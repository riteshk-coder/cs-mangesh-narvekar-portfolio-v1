# ============================================================
# CS Mangesh Narvekar Portfolio — Backend Environment Variables
# ============================================================
# Copy this file to ".env" in the same folder and fill in real
# values. Never commit your actual ".env" file to version control.


# ----------------------------
# Server Configuration
# ----------------------------
# Port the Express server listens on (Render assigns this automatically
# in production via its own PORT variable, but keep a local default).
PORT=5000

# "development" or "production"
NODE_ENV=development


# ----------------------------
# MongoDB Atlas
# ----------------------------
# Connection string from MongoDB Atlas (Database > Connect > Drivers).
# Replace <username>, <password>, <cluster-url> and <database-name>.
# Make sure the database user has read/write access and that your
# server's IP address (or 0.0.0.0/0 for Render) is allow-listed under
# Network Access in Atlas.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/csmn_portfolio?retryWrites=true&w=majority


# ----------------------------
# CORS / Frontend Origins
# ----------------------------
# Comma-separated list of frontend URLs allowed to call this API.
# Include both your local dev URL and your deployed Render Static
# Site URL. No trailing slashes.
FRONTEND_URL=http://localhost:3000,https://your-portfolio-site.onrender.com


# ----------------------------
# Email (Nodemailer)
# ----------------------------
# Recommended: Gmail with a 16-character "App Password"
# (Google Account > Security > 2-Step Verification > App Passwords).
# Do NOT use your normal Gmail login password.
EMAIL_SERVICE=gmail
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASS=your-16-character-app-password

# Display name used as the "From" name on outgoing emails.
EMAIL_FROM_NAME=CS Mangesh Narvekar Portfolio

# --- Alternative: Custom SMTP provider (e.g. Zoho, Hostinger, Outlook) ---
# If you set EMAIL_HOST, it will be used instead of EMAIL_SERVICE.
# EMAIL_HOST=smtp.yourprovider.com
# EMAIL_PORT=587
# EMAIL_SECURE=false


# ----------------------------
# Notification Recipient
# ----------------------------
# Every form submission's full details are emailed to this address.
ADMIN_EMAIL=nagesh.narvekar@example.com
ADMIN_NAME=Nagesh Narvekar
